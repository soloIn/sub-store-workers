# Sub-Store Workers - wrangler.toml 示例配置
# 复制此文件为 wrangler.toml 并填写实际配置

name = "sub-store"
main = "src/index.js"
compatibility_date = "2025-11-17"
compatibility_flags = ["nodejs_compat"]

# D1 数据库绑定
# 本地开发: database_id 使用 "local-dev-database" 即可
# 线上部署: 需要替换为实际的 D1 数据库 ID
[[d1_databases]]
binding = "DB"
database_name = "sub-store-db"
database_id = "__D1_DATABASE_ID__"

# Cron 触发器 - 每 6 小时执行一次
[triggers]
crons = ["0 */6 * * *"]

# 静态资源配置 - Dashboard
[assets]
directory = "./client"
binding = "ASSETS"

# 速率限制配置 - 保护登录接口
[[ratelimits]]
name = "LOGIN_LIMITER"
namespace_id = "1001"
# 每分钟最多 5 次登录尝试
simple = { limit = 5, period = 60 }
